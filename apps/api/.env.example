# ─────────────────────────────────────────────────────────────────────────────
# RIO AI API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rio_ai?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# ── Auth Provider ─────────────────────────────────────────────────────────────
# Set to "firebase" or "auth0" — must match the client app's VITE_AUTH_PROVIDER
AUTH_PROVIDER=firebase

# Firebase (required if AUTH_PROVIDER=firebase)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Auth0 (required if AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.rioapp.io

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@rioapp.io

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project-id
DATADOG_API_KEY=your-datadog-api-key